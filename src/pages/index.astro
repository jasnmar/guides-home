---
import Layout from "../layouts/layout.astro"
import { Image } from 'astro:assets'
import NavCard from "../components/NavCard/NavCard.astro"
import stuckBronco from "../assets/StuckBronco.webp"
import offRoading from "../assets/offroading1.webp"
import rockbronco from "../assets/rocksbronco.webp"
import heroImage from "../assets/sunrise.webp"
---

<Layout 
  title="Home" 
  description="Expert Bronco Off-Roadeo guidance. Prepare for your adventure with our comprehensive resources on recovery, G.O.A.T. modes, and more."
>
<main>

</main>

<main>
  <section class="home--hero-section">
    <Image 
      src={heroImage} 
      alt="Sunrise over an off-roading trail" 
      class="home--hero-image"
      loading="eager"
      fetchpriority="high"
    />
    <div class="home--hero-overlay"></div>
    <h1 class="home--hero-message">Off-Roadeo Guides</h1>
  </section>
  <section class="page-content">
    <p class="home--description">
      Off-Roadeo Guests often have questions after their trip that we can help answer with the information on this site. 
      <br>There's quite a bit of information that we cover during their experience that is stored here for reference. 
    </p>

    <div class="home--nav-cards">
      <NavCard
        title="Recovery"
        link="recovery"
        altText="A bronco stuck in the sand"
        image={stuckBronco}
        >Off-road recoveries occur when the driver and vehicle are unable to
        continue, generally due to a loss of traction.</NavCard
      >
      <NavCard
        title="Offroading"
        link="offroad"
        altText="A bronco sport driving between some trees"
        image={offRoading}
        >Off-Roading, as we talk about it, is done mostly with <b>Broncos</b> and
        <b>Bronco Sports</b>.</NavCard
      >
      <NavCard
        title="Bronco Information"
        link="goatmodes"
        altText="A Red 2 door Bronco on some rocks"
        image={rockbronco}>Technical details related to Broncos.</NavCard
      >
    </div>
    <p>
      This site is maintained by some of the guides at Bronco Off-Roadeo. It is
      not associated with or endorsed by <a
        href="http://www.ford.com"
        target="_blank">Ford</a
      > or <a href="http://www.broncooffroadeo.com" target="_blank"
        >Bronco Off-Roadeo</a
      >.
    </p>
  </section>
</main>
</Layout>



<style>
.home--hero-section {
  position: relative;
  overflow: hidden;
  height: 60vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-bottom: 8px solid var(--clr-primary);
  box-shadow: var(--bs);
  @container (width < 576px) {
    height: 35vh;
    border-bottom: 4px solid var(--clr-primary);
  }
}

.home--hero-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.home--hero-overlay {
  position: absolute;
  inset: 0;
}

.home--hero-message {
  position: relative;
  font-size: 5rem;
  color: var(--clr-text);
  text-align: center;
  font-weight: 800;
  font-family: var(--ff-primary);
  text-transform: uppercase;
  text-shadow: 4px 4px 0px var(--clr-primary);
  letter-spacing: -0.02em;
}

.home--description {
  font-size: 1.5rem;
  color: var(--clr-text-muted);
  margin-bottom: 4rem;
  line-height: 1.6;
  border-left: 4px solid var(--clr-primary);
  padding-left: 2rem;
  @container (width < 576px) {
    padding-left: 1rem;
  }
}

.home--nav-cards {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
  gap: 2rem;
  margin: 4rem 0;
}
</style>