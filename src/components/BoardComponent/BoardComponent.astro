---
import BoardBullets from "../BoardBullets.astro"
import { Image } from "astro:assets"
import { getImage, resolveSvgPath } from "../../utils/boardUtils.astro"
import SvgInliner from "../SvgInliner.astro"

interface Props {
  displayType: string
  large?: string
  small?: string
  image?: string
  bullets?: {
    data: string
    image?: string
  }[]
}
const { displayType, small, large, image, bullets } = Astro.props

const transform = (str?: string) =>
  str ? str.replace(/\*\*(.*?)\*\*/g, "<strong>$1</strong>") : ""

const smallHtml = transform(small)
const largeHtml = transform(large)

const svgPath = resolveSvgPath(image)
const resolvedImage = image && !svgPath ? await getImage(image) : null
---

<div class={"card " + (displayType === "aside" ? "aside" : "")}>
  {
    displayType === "aside" && (
      <aside>
        <header>
          <SvgInliner src="boards/Bronco-bucking.svg" class="asidebronco" />
        </header>
        <section>
          <p class="asideText">{large}</p>
          {
        bullets && (
          <ul class="Aside-UL">
            {bullets.map((bullet) => {
              return <BoardBullets data={bullet.data} image={bullet.image} />
            })}
          </ul>
        )
      }
        </section>
      </aside>
    )
  }
  {
    displayType !== "aside" && (
      <header>
        {small && displayType === "smallLead" && (
          <p class="smallleadsmall" set:html={smallHtml} />
        )}
        {large && !(displayType === "aside") && (
          <p class={"SmallLeadLarge"} set:html={largeHtml} />
        )}
      </header>
    )
  }
  {
    displayType !== "aside" && (

    <section>
      {
        bullets && (
          <ul class="smallLeadUL">
            {bullets.map((bullet) => {
              return <BoardBullets data={bullet.data} image={bullet.image} />
            })}
          </ul>
        )
      }
      {svgPath && <SvgInliner src={svgPath} class="card-image" />}
      {
        resolvedImage && (
          <Image
            class="card-image"
            src={resolvedImage.default}
            alt={large || ""}
            widths={[240, 480, 720, 800, 960, 1200]}
            sizes="(max-width:420px) 240px, (max-width:720px) 400px, 800px"
          />
        )
      }
    </section>
    )
  }
</div>

<style>
  .card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: flex-start;
    gap: 1rem;
    margin-bottom: 2rem;
    width: 100%;
  }

  .card-image {
    width: 100%;
    max-width: 600px;
    height: auto;
    object-fit: contain;
    margin-top: 1rem;
  }

  .smallleadsmall {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 0px;
    font-family: var(--ff-primary);
    color: var(--clr-primary);
    text-transform: uppercase;
    overflow-wrap: break-word;
    word-wrap: break-word;
  }

  .SmallLeadLarge {
    font-size: 3rem;
    line-height: 0.9em;
    text-transform: uppercase;
    margin-bottom: 0.3em;
    font-weight: bold;
    font-family: var(--ff-primary);
    color: var(--clr-text);
    overflow-wrap: break-word;
    word-wrap: break-word;
  }

  .smallLeadUL {
    padding-left: 1.2em;
    list-style: none;
    width: 100%;
  }

  /* Aside (Sidebar) Styles */
  .aside {
    padding: 1.5rem;
    margin-bottom: 2rem;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    color: var(--clr-accent); /* Yellow/Orange in React Orientation Aside */
  }

  .asidebronco {
    width: 200px; /* Increased to match React Aside sizing */
    margin-bottom: 1.5rem;
    align-self: center;
    /* Red Bronco filter from React Aside.css */
    filter: invert(19%) sepia(56%) saturate(2907%) hue-rotate(341deg)
      brightness(95%) contrast(91%);
  }

  .asideText {
    font-size: 1.5rem;
    font-weight: 700;
    font-family: var(--ff-primary);
    text-transform: uppercase;
    line-height: 1.4;
    max-width: 80ch;
    overflow-wrap: break-word;
    word-wrap: break-word;
  }

  .Aside-UL {
    list-style: none;
    text-align: left;
    padding: 0;
    margin: 1.5rem 0 0 0;
    width: 100%;
  }
</style>
