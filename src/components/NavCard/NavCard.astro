---
import { Image } from "astro:assets"
const { link, altText, title, image } = Astro.props
console.log("address: ", link);
---

<div class="navCard--wrapper">
  <a class="navCard--link" href={link}>
    <Image alt={altText} class="navCard--image" src={image} />
    <div class="navCard--inner">
      <div class="navCard--title">{title}</div>
      <div class="navCard--text">
        <slot />
      </div>
    </div>
  </a>
</div>

<style>
  .navCard--wrapper {
    display: flex;
    flex-direction: column;
    background-color: var(--clr-surface);
    border: 1px solid var(--clr-border);
    box-shadow: var(--bs);
    transition: transform 0.2s, box-shadow 0.2s;
    overflow: hidden;
  }

  .navCard--wrapper:hover {
    transform: translate(-4px, -4px);
    box-shadow: 8px 8px 0px var(--clr-primary);
  }

  .navCard--inner {
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    height: 100%;
  }

  .navCard--title {
    font-family: var(--ff-primary);
    font-size: 1.75rem;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 1rem;
    color: var(--clr-primary);
    letter-spacing: 0.05em;
  }

  .navCard--link {
    text-decoration: none;
    color: inherit;
    display: block;
    height: 100%;
  }

  .navCard--image {
    width: 100%;
    height: 240px; /* Fixed height for image consistency */
    object-fit: cover;
    border-bottom: 2px solid var(--clr-border);
    display: block;
    overflow: hidden;
  }

  .navCard--text {
    font-size: 1.1rem;
    color: var(--clr-text-muted);
    line-height: 1.5;
    margin-top: 1rem;
  }

  @media only screen and (max-width: 800px) {
    .navCard--wrapper:hover {
      transform: none;
      box-shadow: var(--bs);
    }
  }
</style>
