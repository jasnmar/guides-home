---
interface ImageInfo {
  image: string
  altText: string
  link?: string
}

interface Props {
  imageInfo?: ImageInfo[]
  title?: string
}

const { imageInfo, title } = Astro.props
---

<div class="recoveryCard--card">
  {title && <h2>{title}</h2>}
  <div class="recoveryCard--content">
    <slot />
  </div>
  <div class="recoveryCard--images">
    {imageInfo && imageInfo.map((img) => (
      img.link ? (
        <a href={img.link} target="_blank" rel="noopener noreferrer">
          <img class="recoveryCard--gear-image" src={img.image} alt={img.altText} />
        </a>
      ) : (
        <img class="recoveryCard--gear-image" src={img.image} alt={img.altText} />
      )
    ))}
  </div>
</div>

<style>
  .recoveryCard--card {
    background-color: var(--clr-surface);
    padding: 2rem;
    border-radius: var(--br); /* 0px sharp corners */
    box-shadow: var(--bs);
    margin-bottom: 3rem;
    border: 1px solid var(--clr-border);
    transition: transform 0.2s;
  }

  .recoveryCard--card:hover {
    border-color: var(--clr-primary);
  }

  .recoveryCard--card h2 {
    margin-top: 0;
    color: var(--clr-accent);
    font-size: 2.25rem;
    font-family: var(--ff-primary);
    text-transform: uppercase;
    font-weight: 800;
    border-bottom: 2px solid var(--clr-primary);
    padding-bottom: 1rem;
    margin-bottom: 1.5rem;
    letter-spacing: 0.05em;
  }

  .recoveryCard--content {
    line-height: 1.7;
    color: var(--clr-text-muted);
    margin-bottom: 2rem;
    font-size: 1.1rem;
  }

  .recoveryCard--images {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    justify-content: flex-start;
  }

  .recoveryCard--gear-image {
    max-width: 100%;
    height: auto;
    max-height: 400px;
    border-radius: var(--br);
    background: white; /* Contrast for icons if they have backgrounds */
    padding: 0.5rem;
    border: 1px solid var(--clr-border);
    box-shadow: var(--bs);
    transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    object-fit: contain;
  }

  .recoveryCard--gear-image:hover {
    transform: translateY(-5px);
    border-color: var(--clr-accent);
  }

  @media (max-width: 640px) {
    .recoveryCard--card {
      padding: 1.5rem;
    }
    .recoveryCard--card h2 {
      font-size: 1.75rem;
    }
  }
</style>
