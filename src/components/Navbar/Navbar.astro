---
const currentPage = Astro.url.pathname
console.log("cp: ", currentPage)
const isOffroad = currentPage.startsWith("/offroad")
const testPage = isOffroad ? "/offroad" : currentPage
const isActive = (href: string) =>
  testPage === href ? "nav--link active" : "nav--link"
---

<header>

    <a class="nav--brand" href="/">Off-Roadeo Guides</a>
    <input
      type="checkbox"
      id="nav-toggle"
      class="nav-toggle"
      aria-label="Toggle navigation"
    />
    <nav>
      <ul class="nav--list">
        <li class="nav--item">
          <a class={isActive("/offroad")} href="/offroad">Offroading</a>
        </li>
        <li class="nav--item">
          <a class={isActive("/recovery")} href="/recovery">Recovery</a>
        </li>
        <li class="nav--item">
          <a class={isActive("/goatmodes")} href="/goatmodes">GOAT Modes</a>
        </li>
      </ul>
    </nav>
    <label for="nav-toggle" class="nav-toggle-label"><span></span></label>

</header>
<script>
  const toggler = document.getElementById("nav-toggler")
  const menu = document.getElementById("nav-menu")

  toggler?.addEventListener("click", () => {
    toggler.classList.toggle("active")
    menu?.classList.toggle("show")
  })
</script>

<style>
  header {
    position: sticky;
    top: 0;
    left: 0;
    z-index: 2;
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    padding: 0 1rem;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.6);
    container-type: inline-size;
    container-name: nav;
  }

  header,
  nav {
    background-image:
      url("/Topo.svg"),
      linear-gradient(rgba(26, 28, 30, 0.9), rgba(26, 28, 30, 0.9));
    background-repeat: repeat;
    background-size: 800px;
    background-position: center;
    width: 100%;
  }
  a {
    text-transform: uppercase;
  }
  nav {
    position: absolute;
    top: 100%;
    left: 0;
    text-align: left;
    scale: 1 0;
    transition: scale 0.2s ease-in-out;
    transform-origin: top;
    @container nav (width > 800px) {
      all: unset;
    }
  }
  .nav--brand {
    font-family: var(--ff-primary);
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--clr-primary);
  }
  .nav-toggle {
    display: none;
  }
  .nav-toggle-label {
    color: var(--clr-primary);
    cursor: pointer;
    border-block: 0.5rem solid #0000;
    span,
    span::before,
    span::after {
      content: "";
      display: block;
      width: 2rem;
      height: 0.25rem;
      background-color: var(--clr-primary);
      border-radius: 2px;
      position: relative;
    }
    span::before,
    span::after {
      content: "";
      position: absolute;
    }
    span::before {
      top: calc(-0.5rem - 2px);
    }
    span::after {
      top: calc(0.5rem + 2px);
    }
    @container nav (width > 800px) {
      display: none;
    }
  }

  .nav-toggle:checked ~ nav {
    display: block;
    scale: 1 1;
    transform-origin: top;
    transition: scale 0.2s ease-in-out;
    & a {
      opacity: 1;
      transition: opacity 0.2s ease-in-out 0.2s;
    }
  }

  nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    @container nav (width > 800px) {
      display: flex;
      align-items: center;
      height: 100%;
    }
  }
  nav ul li {
    margin-bottom: 1rem;
    margin-left: 1rem;
    @container nav (width > 800px) {
      margin-bottom: 0;
    }
  }

  nav a {
    font-family: var(--ff-primary);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--clr-text);
    text-decoration: none;
    transition: opacity 0.1s ease-in-out;
    opacity: 0;
    &:hover {
      color: var(--clr-primary);
    }
    @container nav (width > 800px) {
      opacity: 1;
    }
    &.active {
      color: var(--clr-accent);
    }
  }

