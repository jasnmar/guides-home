---
import { SEO } from "astro-seo"
import { Schema } from "astro-seo-schema"
import "../style.css"
import Navbar from "../components/Navbar/Navbar.astro"
import Footer from "../components/Footer/Footer.astro"

interface Props {
  title?: string
  description?: string
  ogImage?: string
  noindex?: boolean
}

const {
  title = "Off-Roadeo Guides",
  description = "Expert off-roading, recovery gear, and G.O.A.T. mode guidance from official Bronco Off-Roadeo Guides.",
  ogImage = "/sunrise.jpg",
  noindex = false,
} = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png?v=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      href="https://fonts.googleapis.com/css2?family=Oswald:wght@200..700&family=Inter:wght@100..900&family=Ubuntu+Mono:wght@400;700&display=swap"
      as="style"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript
      ><link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Oswald:wght@200..700&family=Inter:wght@100..900&family=Ubuntu+Mono:wght@400;700&display=swap"
      /></noscript
    >
    <meta name="generator" content={Astro.generator} />

    <SEO
      title={title}
      description={description}
      noindex={noindex}
      canonical={`https://www.offroadeoguides.com${Astro.url.pathname}`}
      openGraph={{
        basic: {
          title: `${title} | Off-Roadeo Guides`,
          type: "website",
          image: ogImage,
        },
      }}
      twitter={{
        card: "summary_large_image",
        title: `${title} | Offroading, Recovery, and Bronco Information`,
        description: description,
        image: ogImage,
      }}
    />
    <Schema
      item={{
        "@context": "https://schema.org",
        "@type": "WebSite",
        name: "Off-Roadeo Guides",
        url: "https://www.offroadeoguides.com",
        description:
          "Information and resources for Bronco and Bronco Sport off-roading enthusiasts, maintained by experienced trail guides.",
        publisher: {
          "@type": "Organization",
          name: "Martin Consulting LLC",
        },
        mainEntity: {
          "@type": "Service",
          serviceType: "Off-Roading Education",
          provider: {
            "@type": "Organization",
            name: "Off-Roadeo Guides",
          },
          areaServed: {
            "@type": "Place",
            name: "United States",
          },
        },
        hasOfferCatalog: {
          "@type": "OfferCatalog",
          name: "Off-Roading Guides",
          itemListElement: [
            {
              "@type": "Offer",
              itemOffered: {
                "@type": "Service",
                name: "Recovery Techniques",
              },
            },
            {
              "@type": "Offer",
              itemOffered: {
                "@type": "Service",
                name: "G.O.A.T. Mode Tutorials",
              },
            },
          ],
        },
      }}
    />

    <style is:global></style>
  </head>
  <body>
    <Navbar />
    <slot />
    <Footer />
  </body>
</html>
